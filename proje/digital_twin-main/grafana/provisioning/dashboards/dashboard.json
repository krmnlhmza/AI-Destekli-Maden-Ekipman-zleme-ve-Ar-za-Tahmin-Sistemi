{
  "title": "Maden Dijital İkiz - Ekipman İzleme",
  "uid": "maden-digital-twin",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Konveyör 01 - Sıcaklık",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT time, temperature FROM sensor_readings WHERE equipment_id='conveyor_01' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Konveyör 01 - Titreşim",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT time, vibration FROM sensor_readings WHERE equipment_id='conveyor_01' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Anomali Sayısı (Son 24 Saat)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) as anomaly_count FROM anomaly_logs WHERE time >= NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Pompa 01 - Basınç",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT time, pressure FROM sensor_readings WHERE equipment_id='pump_01' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "pressurembar",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 750 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Kırıcı 01 - Akım",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT time, current FROM sensor_readings WHERE equipment_id='crusher_01' AND $__timeFilter(time) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Son Anomaliler",
      "type": "table",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 12 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [{
        "rawSql": "SELECT time, equipment_id, anomaly_score, description FROM anomaly_logs ORDER BY time DESC LIMIT 10",
        "format": "table"
      }]
    }
  ]
}
